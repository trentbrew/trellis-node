{
	"name": "myapp",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 4000",
		"dev:client": "VITE_PRESENCE_RELAY_URL=ws://localhost:8231/rt vite dev --port 4000",
		"dev:trellis": "node scripts/trellis-init.mjs && node scripts/trellis-serve.mjs",
		"dev:relay": "node ../../scripts/demo-relay.mjs",
		"dev:all": "concurrently -k -n trellis,relay,vite -c cyan,magenta,green \"pnpm dev:trellis\" \"pnpm dev:relay\" \"pnpm dev:client\"",
		"trellis:init": "node scripts/ensure-trellis-build.mjs && node scripts/trellis-init.mjs",
		"trellis:seed": "node scripts/trellis-seed.mjs",
		"trellis:dedupe": "node scripts/trellis-dedupe.mjs",
		"trellis:ontology": "node scripts/register-collection-ontology.mjs",
		"trellis:vcs-init": "node scripts/trellis-vcs-init.mjs",
		"lane:check": "node scripts/lane-materialize-check.mjs",
		"trellis:serve": "node scripts/trellis-serve.mjs",
		"wc:host": "node wc/server.mjs",
		"wc:start": "node scripts/wc-start.mjs",
		"preinstall": "node scripts/ensure-trellis-build.mjs",
		"build": "NODE_OPTIONS=--max-old-space-size=8192 vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"test:unit": "vitest run",
		"test:e2e": "playwright install && playwright test",
		"test:wc": "WC_E2E=1 playwright install && WC_E2E=1 playwright test wc/wc-boot.e2e.ts",
		"test": "npm run test:unit && npm run test:e2e",
		"agent:add": "node scripts/agent-mutate.mjs"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.9.1",
		"concurrently": "^9.2.1",
		"mdsvex": "^0.12.7",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.16",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"@fontsource/ibm-plex-sans": "^5.2.8",
		"bits-ui": "^2.18.1",
		"carbon-icons-svelte": "^13.11.0",
		"trellis": "file:../..",
		"ws": "^8.20.1",
		"zod": "^3.25.0"
	}
}
