  "author": {
    "name": "Trent Brew",
    "email": "tbrew@turtle.tech",
    "url": "https://trellis.computer"
  },
  "type": "module",
  "scripts": {
    "automd": "npx automd@latest --input **/*.md --watch",
    "build": "NODE_OPTIONS=--max_old_space_size=6000 nuxt build",
    "clean": "rm -rf .nuxt .data dist .output node_modules yarn.lock package-lock.json && npm i && npm rebuild",
    "dev": "nuxt dev --port 7998 --host 0.0.0.0",
    "format": "npx prettier --write .",
    "generate": "nuxt generate",
    "generate:all": "npm run generate:blocks && npm run generate:components && npm run generate:prose",
    "generate:blocks": "node scripts/create-blocks.js && npx prettier --write ./server/utils/**",
    "generate:components": "node scripts/create-components && npx prettier --write ./server/utils/**",
    "generate:prose": "node scripts/create-prose.js && npx prettier --write ./server/utils/**",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "preview": "nuxt preview",
    "sync:skills": "node scripts/sync-skills.js",
    "vercel:check": "node scripts/vercel-docs.mjs check",
    "vercel:deploy": "node scripts/vercel-docs.mjs deploy",
    "vercel:link": "node scripts/vercel-docs.mjs link"
  },
  "lint-staged": {
    "*": [
      "npx -y automd@latest --input **/*.md",
      "bash -c 'npm run generate:all'",
      "prettier --write"
    ],
    "*.{js,ts,vue}": [
      "eslint --fix"
    ]
  },
