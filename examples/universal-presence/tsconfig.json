{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "verbatimModuleSyntax": true
  },
  "include": ["shared.ts", "vite-env.d.ts", "react/**/*", "vue/**/*", "svelte/**/*", "vite.config.ts"]
}
