{
  "name": "trellis-universal-presence-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:relay-client": "VITE_PRESENCE_RELAY_URL=ws://localhost:${RELAY_PORT:-8231}/rt vite",
    "dev:all": "concurrently -k -n relay,vite -c magenta,green \"RELAY_PORT=${RELAY_PORT:-8231} npm run relay\" \"npm run dev:relay-client\"",
    "build": "vite build",
    "preview": "vite preview",
    "preinstall": "node ../../scripts/ensure-linked-trellis.mjs",
    "relay": "node ../../scripts/demo-relay.mjs"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "svelte": "^5.55.2",
    "trellis": "link:../..",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "^5.6.0",
    "vite": "^6.3.1"
  }
}
