{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["vite/client", "react", "react-dom"]
  },
  "include": [
    "schema.ts",
    "bootstrap.ts",
    "nav-links.ts",
    "react/**/*",
    "vue/**/*",
    "svelte/**/*",
    "vite.config.ts"
  ]
}
